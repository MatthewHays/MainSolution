<Application x:Class="GuitarPractice.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Chord box style -->
        <Style x:Key="ChordBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1F2A44"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style x:Key="ChordBoxActiveStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style x:Key="ChordTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Application.Resources>
</Application>
