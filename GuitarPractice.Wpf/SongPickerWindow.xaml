<Window x:Class="GuitarPractice.Wpf.SongPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select a Song"
        Width="520" Height="460"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF121820">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF37474F"/>
                    <Setter Property="Foreground" Value="#FF78909C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Multiple songs found — pick one:"
                   Foreground="#FF90A4AE"
                   FontSize="13"
                   Margin="0,0,0,10"/>

        <!-- Results list -->
        <Border Grid.Row="1"
                Background="#FF0D1117"
                CornerRadius="6"
                Margin="0,0,0,12">
            <ListView x:Name="ResultsList"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="White"
                      FontSize="13"
                      SelectionMode="Single"
                      SelectionChanged="ResultsList_SelectionChanged"
                      MouseDoubleClick="ResultsList_MouseDoubleClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1F2A44"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayTitle}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- Rating stars if rated -->
                            <TextBlock Grid.Column="1"
                                       Foreground="#FFFFCA28"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRating}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="★ "/>
                                <Run Text="{Binding RatingDisplay}"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,10,0"
                    Background="#FF37474F"
                    Click="CancelButton_Click"/>
            <Button x:Name="SelectButton"
                    Content="Select Song" Width="110"
                    IsEnabled="False"
                    Click="SelectButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
