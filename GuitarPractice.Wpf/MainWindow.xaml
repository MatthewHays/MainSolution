<Window x:Class="GuitarPractice.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guitar Practice" Height="460" Width="640"
        MinHeight="400" MinWidth="500"
        ResizeMode="CanResizeWithGrip"
        Background="#FF121820">

    <Window.Resources>
        <!-- Dark text box -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1F2A44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A4A6A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <!-- Action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF37474F"/>
                    <Setter Property="Foreground" Value="#FF78909C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Play button (green) -->
        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="FontSize" Value="15"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF388E3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF37474F"/>
                    <Setter Property="Foreground" Value="#FF78909C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Stop button (red) -->
        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FFC62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD32F2F"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF37474F"/>
                    <Setter Property="Foreground" Value="#FF78909C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF78909C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Search row -->
            <RowDefinition Height="Auto"/>   <!-- Song title / status -->
            <RowDefinition Height="*"/>      <!-- Chord display -->
            <RowDefinition Height="Auto"/>   <!-- Transport controls -->
            <RowDefinition Height="Auto"/>   <!-- BPM / beat indicator -->
            <RowDefinition Height="Auto"/>   <!-- Volume -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Search ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SongSearchBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     Text="Whisky in a Jar"
                     ToolTip="Type a song title and press Enter or click Look Up"
                     KeyDown="SongSearchBox_KeyDown"/>
            <Button x:Name="LookupButton"
                    Grid.Column="1"
                    Content="Look Up Chords"
                    Style="{StaticResource ActionButton}"
                    Click="LookupButton_Click"/>
        </Grid>

        <!-- ── Row 1: Song title / status ── -->
        <TextBlock x:Name="SongTitleLabel"
                   Grid.Row="1"
                   Margin="0,10,0,4"
                   Text="Enter a song and click Look Up Chords"
                   Foreground="#FF90A4AE"
                   FontSize="13"
                   FontStyle="Italic"
                   TextWrapping="Wrap"/>

        <!-- ── Row 2: Chord display ── -->
        <Border Grid.Row="2"
                Background="#FF0D1117"
                CornerRadius="8"
                Margin="0,0,0,10"
                Padding="8">
            <Grid>
                <TextBlock x:Name="NoChordLabel"
                           Text="No chords loaded"
                           Foreground="#FF455A64"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <!-- Chords wrap panel — populated in code -->
                <WrapPanel x:Name="ChordsPanel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- ── Row 3: Transport ── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="PlayButton"
                    Content="▶  Play"
                    Style="{StaticResource PlayButton}"
                    Width="100"
                    Margin="0,0,10,0"
                    IsEnabled="False"
                    Click="PlayButton_Click"/>
            <Button x:Name="StopButton"
                    Content="■  Stop"
                    Style="{StaticResource StopButton}"
                    Width="100"
                    Margin="0,0,20,0"
                    IsEnabled="False"
                    Click="StopButton_Click"/>

            <!-- Beats per chord -->
            <TextBlock Text="Beats / chord:"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ComboBox x:Name="BeatsPerChordCombo"
                      Width="55"
                      Height="32"
                      Background="#FF1F2A44"
                      Foreground="White"
                      BorderBrush="#FF3A4A6A"
                      FontSize="13"
                      SelectedIndex="1"
                      SelectionChanged="BeatsPerChordCombo_SelectionChanged">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF1F2A44"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="8"/>
            </ComboBox>
        </StackPanel>

        <!-- ── Row 4: BPM + beat indicator ── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Tempo:"
                       Foreground="#FF90A4AE"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Margin="0,0,10,0"/>

            <Slider x:Name="BpmSlider"
                    Grid.Column="1"
                    Minimum="20" Maximum="240" Value="80"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Foreground="#FF1565C0"
                    ValueChanged="BpmSlider_ValueChanged"/>

            <TextBlock x:Name="BpmLabel"
                       Grid.Column="2"
                       Text="80 BPM"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Width="70"
                       Margin="0,0,14,0"/>

            <!-- Beat flash indicator -->
            <Border x:Name="BeatIndicator"
                    Grid.Column="3"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#FF37474F"
                    VerticalAlignment="Center">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded"/>
                </Border.Triggers>
            </Border>
        </Grid>

        <!-- ── Row 5: Volume ── -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Volume:"
                       Foreground="#FF90A4AE"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Margin="0,0,10,0"/>

            <Slider x:Name="VolumeSlider"
                    Grid.Column="1"
                    Minimum="0" Maximum="100" Value="80"
                    TickFrequency="5"
                    IsSnapToTickEnabled="False"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Foreground="#FF1565C0"
                    ValueChanged="VolumeSlider_ValueChanged"/>

            <TextBlock x:Name="VolumeLabel"
                       Grid.Column="2"
                       Text="80 %"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Width="50"/>
        </Grid>
    </Grid>
</Window>
